{
  "manifest_version": 3,
  "name": "YouTube Comment Rewriter",
  "version": "3.0.0",
  "description": "Rewrites YouTube comments and live chat using customizable replacement text.",
  "permissions": [
    "storage"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*"
      ],
      "js": [
        "content.js"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ]
}
